          "info": {
            "name": "Retrieves Orders",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.example.com/orders",
            "auth": {
              "type": "apikey",
              "key": "api-key",
              "value": "{{api-key}}",
              "placement": "header"
            }
          },
          "docs": "Returns a list of all orders for the authenticated user."
        },
        {
          "info": {
            "name": "Orders Create Order",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.example.com/orders",
