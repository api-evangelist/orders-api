              "type": "apikey",
              "key": "api-key",
              "value": "{{api-key}}",
              "placement": "header"
            }
          },
          "docs": "Creating a new order for sending to a recipient."
        },
        {
          "info": {
            "name": "Orders Retrieve Order",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.example.com/orders/:orderId",
            "params": [
              {
                "name": "orderId",
